{
  "name": "digitalresume",
  "version": "1.0.0",
  "description": "A custom WordPress theme for digital resumes.",
  "main": "index.php",
  "scripts": {
    "build-css": "node-sass --include-path node_modules assets/scss/main.scss style.css",
    "build-css-dev": "sass --load-path=node_modules assets/scss/main.scss:style.css --style expanded --source-map",
    "watch-css": "sass --load-path=node_modules assets/scss/main.scss:style.css --watch --style expanded",
    "watch-js": "webpack --watch --mode production",
    "zip": "zip -r digitalresume.zip . -x '*.git*' 'node_modules/*' 'vendor/*'",
    "start": "npm-run-all --parallel watch-css watch-js",
    "build-js": "webpack --mode production"
  },
  "author": "David Hicka",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.77.6",
    "style-loader": "^4.0.0",
    "terser": "^5.31.1",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4"
  },
  "homepage": "http://davidhicka.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hickad/digitalresume.git"
  },
  "bugs": {
    "url": "https://github.com/hickad/digitalresume/issues"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.3",
    "js-cookie": "^3.0.5",
    "mini-css-extract-plugin": "^2.9.0",
    "sass-loader": "^14.2.1"
  }
}
